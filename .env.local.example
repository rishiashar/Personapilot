# Copy this file to .env.local and fill in your key.
# The OpenAI key is used server-side only (never exposed to the browser).
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override the model used for participant role-play.
# OPENAI_MODEL=gpt-4o-mini

# The ElevenLabs key powers participant voice output (text-to-speech).
# Used server-side only (never exposed to the browser). Without it, the
# interview still works and shows text-only responses.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
